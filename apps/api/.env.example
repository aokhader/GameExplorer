# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000

# Database (Prisma 7 - configured in prisma.config.ts)
DATABASE_URL="postgresql://boardgame:dev_password@localhost:5432/boardgames?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-key-change-in-production-use-openssl-rand-base64-32
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-secret-key-change-in-production
REFRESH_TOKEN_EXPIRES_IN=7d

# AWS S3 (for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session
SESSION_SECRET=your-session-secret-change-in-production

# Production optimizations
MAX_REQUEST_SIZE=10mb
ENABLE_COMPRESSION=true